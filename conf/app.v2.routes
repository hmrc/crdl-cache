# v2 routes to support crdl cache admin frontend
# Overlay's prod.routes to add in new endpoint

->      /       prod.Routes

# V2 endpoints to support crdl-cache-admin-frontend
GET     /crdl-cache/v2/offices/summaries            uk.gov.hmrc.crdlcache.controllers.CustomsOfficeListsV2Controller.fetchCustomsOfficeListSummaries(pageNum: Int, pageSize: Int, activeAt: Option[Instant], referenceNumber: Option[String], countryCode: Option[String], officeName: Option[String], phase: Option[String], domain: Option[String])
GET     /crdl-cache/v2/offices/:referenceNumber     uk.gov.hmrc.crdlcache.controllers.CustomsOfficeListsV2Controller.fetchCustomsOfficeDetail(referenceNumber: String, activeAt: Option[Instant])
GET     /crdl-cache/admin/lists                     uk.gov.hmrc.crdlcache.controllers.CodeListsV2Controller.fetchCodeListVersions(pageNum: Int, pageSize: Int, codeListCode: Option[String], phase: Option[String], domain: Option[String])
GET     /crdl-cache/v2/snapshot/:code               uk.gov.hmrc.crdlcache.controllers.CodeListsV2Controller.getSnapshot(code: String)